# =============================================================================
# CRM Support Copilot — environment variables (EXAMPLE ONLY)
# =============================================================================
# PURPOSE:
#   Templates every secret / config value this app needs. Copy this file to
#   `.env.local` and fill in real values. Never commit `.env.local`.
#
# HOW IT CONNECTS:
#   Next.js loads `.env.local` at runtime.
#   · NEXT_PUBLIC_*  → bundled into the browser (Supabase URL + anon key only)
#   · All other vars → server-only (API routes, seed scripts)
#
# SETUP:
#   cp .env.local.example .env.local
# =============================================================================

# --- Supabase (create a project at https://supabase.com) -------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role: FULL database access. Server / scripts only. Never expose.
# Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- AI provider selection -------------------------------------------------
# Recommended for free demos: gemini
# Options: gemini | claude | openai
AI_PROVIDER=gemini

# --- Google Gemini (FREE tier — recommended) -------------------------------
# Get a key: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_key_here
# Optional override (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# --- Anthropic Claude (paid / credits) -------------------------------------
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- OpenAI (paid; also used later for embeddings stretch) -----------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here
