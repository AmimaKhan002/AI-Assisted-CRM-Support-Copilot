# =============================================================================
# CRM Support Copilot — environment variables (EXAMPLE ONLY)
# =============================================================================
# Copy to .env.local and fill in real values. Never commit .env.local.
# =============================================================================

# --- Supabase (Project Settings → API) -------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Groq AI (FREE chat) — https://console.groq.com/keys -------------------
# Used for summarize + draft reply. Groq does NOT offer embeddings.
GROQ_API_KEY=your_groq_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Embeddings for RAG (Step 15) — pick ONE -------------------------------
# Option A (recommended): OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Option B (free tier): Google Gemini embeddings
# https://aistudio.google.com/apikey
# GOOGLE_GENERATIVE_AI_API_KEY=...
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Without either key, KB search falls back to keywords automatically.
